# =============================================================================
# Trading Intelligence Agent — Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)
# =============================================================================

# LLM Configuration
# For Anthropic direct:
ANTHROPIC_API_KEY=sk-ant-...
LLM_GATEWAY_URL=https://api.anthropic.com
# as of 2026-03-27 the latest model is claude-sonnet-4-6
# but you can you the previous one claude-sonnet-4-20250514
LLM_MODEL=claude-sonnet-4-6
# OpenAI-compatible model examples from the official models docs:
# gpt-5.1, gpt-5, gpt-5-mini, gpt-5-nano, gpt-5-pro, gpt-4.1
OPENAI_LLM_MODEL=gpt-5-mini
LLM_MODEL_FAST=claude-haiku-4-5-20251001

# Per-agent model assignment (cost / quality routing)
# SignalAgent runs every cycle — use a cheap fast model
LLM_MODEL_SIGNAL=claude-haiku-4-5-20251001
# SelfAssessmentAgent reasons over historical data — use the strongest model
LLM_MODEL_ASSESSMENT=claude-sonnet-4-6
# Internal text summarization (news, etc.) — use a cheap model
LLM_MODEL_SUMMARIZER=claude-haiku-4-5-20251001

# For Gateway (OpenAI-compatible):
# LLM_GATEWAY_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-proj-...

# Trading
TRADING_SYMBOLS=["BTC/USDT","ETH/USDT"]
TRADING_TIMEFRAMES=["15m","1h","4h","1d"]
MAX_RISK_PCT=1.0
MAX_POSITION_PCT=5.0
MIN_CONFIDENCE=70
DRY_RUN=true

# Market data
MARKET_DATA_SOURCE=synthetic
MARKET_DATA_FALLBACK_TO_SYNTHETIC=true
CCXT_EXCHANGE=binance

# Backtesting
BACKTEST_LOOKBACK_DAYS=30
MIN_TRADES_ASSESSMENT=10
WIN_RATE_THRESHOLD=0.55
ASSESSMENT_INTERVAL_HOURS=24

# Infrastructure
PORT=8080
LOG_LEVEL=INFO
ENVIRONMENT=development
AGENT_ID=trading-intelligence-agent

# Backing Services (production)
# REDIS_URL=redis://redis:6379
# DATABASE_URL=postgresql://user:pass@aurora-host:5432/trading_agent
# S3_CONVERSATION_BUCKET=advisor-conversations

# =============================================================================
# Autonomous Signal Service — Scan, Prediction, Adaptation, Telegram
# =============================================================================

# Rate limiting — max LLM calls across all pairs within the period
SCAN_RATE_LIMIT_MAX_CALLS=2
SCAN_RATE_LIMIT_PERIOD_SECONDS=3600

# Scan cadence (seconds per timeframe)
SCAN_INTERVAL_5M=300
SCAN_INTERVAL_15M=900
SCAN_INTERVAL_1H=3600
SCAN_INTERVAL_4H=14400
SCAN_INTERVAL_1D=86400

# Prediction evaluation horizons (number of candles after signal)
PREDICTION_EVAL_HORIZON_5M=6
PREDICTION_EVAL_HORIZON_15M=6
PREDICTION_EVAL_HORIZON_1H=8
PREDICTION_EVAL_HORIZON_4H=6
PREDICTION_EVAL_HORIZON_1D=5
MIN_EVALUATED_PREDICTIONS_FOR_ADAPTATION=25

# Adaptation control
ENABLE_AUTONOMOUS_ADAPTATION=false
ADAPTATION_INTERVAL_HOURS=24
MAX_PARAMETER_MUTATIONS_PER_CYCLE=2
ROLLBACK_ON_SHORT_WINDOW_DEGRADATION=true

# KPI thresholds that trigger adaptation
MIN_DIRECTIONAL_ACCURACY=0.50
MIN_TP1_REACH_RATE=0.35
MAX_FALSE_POSITIVE_RATE=0.55
MAX_FAILED_PROMOTIONS_BEFORE_FREEZE=3

# =============================================================================
# News & Sentiment — external context for signal generation
# =============================================================================
NEWS_ENABLED=true
# CryptoPanic — free tier, crypto-only news with sentiment tags
# Get a key at https://cryptopanic.com/developers/api/
# CRYPTOPANIC_API_KEY=
# Alpha Vantage — free tier (25 req/day) with pre-scored sentiment + ticker relevance
# Get a key at https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=
# NewsAPI.org — free tier 100 req/day, broad coverage (needs LLM for sentiment)
# Get a key at https://newsapi.org/register
# NEWSAPI_API_KEY=
NEWS_LOOKBACK_HOURS=24
NEWS_MAX_ARTICLES=15
NEWS_CACHE_TTL_SECONDS=1800
FEAR_GREED_CACHE_TTL_SECONDS=21600
NEWS_HTTP_TIMEOUT=8.0

# =============================================================================
# Liquidity / Order Book — microstructure context
# =============================================================================
LIQUIDITY_ENABLED=true
LIQUIDITY_DEPTH=100
LIQUIDITY_WALL_MULTIPLIER=5.0
LIQUIDITY_CACHE_TTL_SECONDS=60

# =============================================================================
# Knowledge RAG — embed past signal outcomes for similarity retrieval
# =============================================================================
# Provider: "sentence_transformers" (local, free) or "openai" (uses gateway/OpenAI)
EMBED_PROVIDER=sentence_transformers
EMBED_LOCAL_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBED_OPENAI_MODEL=text-embedding-3-small
EMBED_DIMENSION=384

VECTOR_STORE_ENABLED=true
# Defaults under TRADING_AGENT_DATA_DIR/vector_store if not set
# VECTOR_STORE_DIR=
VECTOR_OUTCOMES_COLLECTION=signal_outcomes
VECTOR_DEFAULT_TOP_K=5
VECTOR_RETENTION_DAYS=180

# Telegram
# TELEGRAM_BOT_TOKEN=<bot token from @BotFather>
# TELEGRAM_CHANNEL_ID=-100xxxxxxxxx
# TELEGRAM_THREAD_ID=
TELEGRAM_PUBLISH_SIGNALS=true
TELEGRAM_PUBLISH_EVALUATIONS=false
TELEGRAM_PUBLISH_STRATEGY_CHANGES=true
TELEGRAM_PUBLISH_DEGRADATION_ALERTS=true
